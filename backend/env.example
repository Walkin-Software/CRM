# ── Google Calendar / Meet ─────────────────────────────────────
# Paste the entire service account JSON as a single-line string (escape quotes)
# OR leave blank to disable Google Meet link generation in bookings
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
# Calendar ID to create events on — use "primary" for the service account's default
GOOGLE_CALENDAR_ID=primary

# ── SMTP (email follow-ups) ────────────────────────────────────
# Leave blank to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Company Description ────────────────────────────────────────
# AI uses ONLY this text to answer candidate questions on calls & WhatsApp.
# Fill in your actual course/service details — fees, duration, curriculum, etc.
COMPANY_DESCRIPTION=Walkin Software is a technology education company. We offer software development courses including Python programming, full-stack web development (React + Node.js), data science, machine learning, and Java development. Course duration is 3 to 6 months depending on the program. Classes are held online via live instructor-led sessions, Monday to Saturday, 7 PM to 9 PM IST. Course fees range from INR 25000 to INR 75000 depending on the course selected. We provide hands-on projects, placement assistance, and dedicated mentorship throughout. We have successfully placed 500 plus students in top software companies. The demo session is a free 30-minute walkthrough covering course curriculum, live class format, projects, placement process, and fee structure. You can book the demo at any convenient time and our team will confirm the slot.

# ── Observability ──────────────────────────────────────────────
ENABLE_METRICS=true
# Leave blank to disable Sentry error tracking
SENTRY_DSN=
AI_MEMORY_ENABLED=false

# ── Local Testing Flags ───────────────────────────────────────
# Set true to skip real Twilio/Stripe calls (returns mock responses)
MOCK_SERVICES=false

# ── Frontend ──────────────────────────────────────────────────
VITE_API_BASE_URL=https://localhost:3003
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51TTbddIFlBY5f2XIu2ZLlfI5Hm7g98aKwBX4TFjdZjjOtpBEVySGGrUXwMdupDqCurCkjeViPEPIrVWvAQfeQ4Lc00XeLtNSmg
VITE_APP_NAME=AI Phone Agent
