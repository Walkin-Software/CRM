# =============================================================
# AI Phone Agent — Environment Variables
# =============================================================

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── API / Security ───────────────────────────────────────────
CRM_SERVICE_PORT=3003
JWT_SECRET=super-secret-agent-key-7829730090
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
ALLOWED_ORIGINS=["https://localhost:5173","http://localhost:5173","https://127.0.0.1:5173","http://127.0.0.1:5173","https://tabby-fester-rejoin.ngrok-free.dev"]

# Internal token used by Celery tasks to call backend's /internal/* endpoints
# Must match what the Celery worker sends in the X-Internal-Token header
INTERNAL_API_TOKEN=local-internal-token
# Full base URL of THIS backend so Celery tasks can POST to internal endpoints
# e.g. https://localhost:3003  (no trailing slash)
INTERNAL_API_BASE_URL=https://localhost:3003

# ── MySQL Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_phone_agent
DB_USER=root
DB_PASSWORD=root
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/ai_phone_agent
DB_POOL_SIZE=10

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600
DASHBOARD_CACHE_TTL_SECONDS=60

# ── Celery Workers ─────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Service Ports (legacy references, backend is the only service now) ─────
CALL_SERVICE_PORT=3001
AI_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3004
SCHEDULING_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007

# ── Twilio ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC3fb9baa329220e9d154d7c5953b4f800
TWILIO_AUTH_TOKEN=d5aec1ace097d5782d0198e31a795638
TWILIO_PHONE_NUMBER=+18453932954
TWILIO_WHATSAPP_NUMBER=whatsapp:+917829730090
TWILIO_WEBHOOK_URL=https://tabby-fester-rejoin.ngrok-free.dev
# Twilio API Key + Secret — needed for programmatic voice client tokens
# Create at: https://console.twilio.com/us1/account/keys-credentials/api-keys
TWILIO_API_KEY=
TWILIO_API_SECRET=

