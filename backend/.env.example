# =============================================================
# AI Phone Agent — Environment Variables Template
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.
# =============================================================

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── API Gateway ───────────────────────────────────────────────
API_GATEWAY_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MySQL Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_phone_agent
DB_USER=root
DB_PASSWORD=radhe123
DB_POOL_SIZE=10
DATABASE_URL=mysql+aiomysql://root:radhe123@localhost:3306/ai_phone_agent

# ── Redis / Cache ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ── Service Ports ─────────────────────────────────────────────
CALL_SERVICE_PORT=3001
CALL_SERVICE_URL=http://localhost:3001

AI_SERVICE_PORT=3002
AI_SERVICE_URL=http://localhost:3002

CRM_SERVICE_PORT=3003
CRM_SERVICE_URL=http://localhost:3003

NOTIFICATION_SERVICE_PORT=3004
NOTIFICATION_SERVICE_URL=http://localhost:3004

SCHEDULING_SERVICE_PORT=3005
SCHEDULING_SERVICE_URL=http://localhost:3005

ANALYTICS_SERVICE_PORT=3006
ANALYTICS_SERVICE_URL=http://localhost:3006

PAYMENT_SERVICE_PORT=3007
PAYMENT_SERVICE_URL=http://localhost:3007

# ── Twilio ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12025550100
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=http://localhost:3001/webhooks/twilio

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_WHISPER_MODEL=whisper-1

# ── AssemblyAI STT ────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_api_key
ASSEMBLYAI_API_BASE_URL=https://api.assemblyai.com/v2
ASSEMBLYAI_SPEECH_MODEL=universal-2
ASSEMBLYAI_POLL_INTERVAL_SECONDS=2
ASSEMBLYAI_TRANSCRIPT_TIMEOUT_SECONDS=180
ASSEMBLYAI_REALTIME_WS_URL=wss://agents.assemblyai.com/v1/ws
ASSEMBLYAI_REALTIME_VOICE=ivy
REALTIME_CALLS_ENABLED=false

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=INR

# ── Local Testing Flags ───────────────────────────────────────
MOCK_SERVICES=true  # Set to false to use real Twilio/OpenAI/Stripe

# ── Frontend ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3003  # Directly to CRM for now or proxy
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_APP_NAME=AI Phone Agent

# ── SMTP (optional email notifications) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="AI Phone Agent <noreply@phoneagent.ai>"
